10 LET M = 68

20 DIM X (M)
30 DIM Y (M)

40 FOR I = 0 TO M

50   IF RND(1) * 10 > 5 THEN 90

60   LET X(I) = 1
70   PRINT "*";
80   GOTO 110

90   LET X(I) = 0
100   PRINT " ";

110 NEXT I
120 PRINT

130 FOR T = 0 TO 25

140   FOR I = 0 TO M

150     LET C = 0
160     FOR Z = I-2 TO I+2
170       IF Z < 0 THEN 200
180       IF Z > M THEN 200
190       LET C = C + X(Z)
200     NEXT Z

210     IF C = 3 THEN 290 

220     IF X(I) = 0 THEN 250

230     IF C = 5 THEN 290
240     GOTO 260

250     IF C = 2 THEN 290

260     LET Y(I) = 0
270     PRINT " ";
280     GOTO 310

290     LET Y(I) = 1
300     PRINT "*";

310   NEXT I
320   PRINT

330   FOR I = 0 TO M
340     LET X(I) = Y(I)
350   NEXT I

360 NEXT T
370 REM GOTO 40
999 END
